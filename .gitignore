# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/e2e/
/playwright-report/
/test-results/
playwright.config.ts
playwright.*.config.ts

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Documentação interna e configuração local (não commitar)
/docs/
/.claude/

# Portal users (não commitar — contém códigos de acesso)
users.private.json

# SQLite local (não commitar — banco de dados privado)
dev.db
dev.db-shm
dev.db-wal
dev.db-info
prisma/dev.db
